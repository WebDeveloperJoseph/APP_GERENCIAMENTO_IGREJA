generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id                 String        @id @default(uuid())
  name               String
  email              String?       @unique
  password           String?
  mustChangePassword Boolean       @default(false)
  phone              String?
  photoUrl           String?
  birthDate          DateTime?
  role               Role          @default(MEMBRO)
  isSuperAdmin       Boolean       @default(false)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  transactions       Transaction[]
  createdEvents      Event[]
  pushTokens         PushToken[]

  @@map("members")
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  platform  String
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@map("push_tokens")
}

model Event {
  id            String   @id @default(uuid())
  title         String
  description   String?
  location      String?
  coverImageUrl String?
  startDate     DateTime
  endDate       DateTime
  isPublic      Boolean  @default(true)
  createdById   String?
  createdBy     Member?  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startDate])
  @@index([createdById])
  @@map("events")
}

model Transaction {
  id          String              @id @default(uuid())
  type        TransactionType
  category    TransactionCategory
  value       Float
  date        DateTime            @default(now())
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  memberId    String?
  member      Member?             @relation(fields: [memberId], references: [id])

  @@map("transactions")
}

model Asset {
  id              String      @id @default(uuid())
  name            String
  imageUrl        String?
  description     String?
  category        String
  value           Float
  acquisitionDate DateTime?
  location        String?
  status          AssetStatus @default(ATIVO)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("assets")
}

model StoredImage {
  id        String   @id @default(uuid())
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())

  @@map("stored_images")
}

enum Role {
  MEMBRO
  VOLUNTARIO
  TESOUREIRO
  PASTOR
  DIRETOR_PATRIMONIO
  ADMIN
}

enum TransactionType {
  ENTRADA
  SAIDA
}

enum TransactionCategory {
  DIZIMO
  OFERTA
  ALUGUEL
  ENERGIA
  AGUA
  MANUTENCAO
  OUTROS
}

enum AssetStatus {
  ATIVO
  MANUTENCAO
  BAIXADO
}
